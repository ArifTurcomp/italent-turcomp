# Backend-only environment variables.
# Copy this file to .env and fill in your values. Never commit .env to git.
API_HOST=0.0.0.0
API_PORT=8000
APP_ENV=development
CORS_ORIGINS=http://localhost:19006,http://localhost:8081,http://localhost:3000
CORS_ORIGIN_REGEX=
# Local Docker uses MySQL. Render/Aiven may use PostgreSQL or MySQL.
# postgres://, mysql://, and Aiven MySQL ssl-mode query strings are normalized automatically.
DATABASE_URL=mysql+pymysql://italent:italent_password@localhost:3307/italent_db
DATABASE_CONNECT_RETRIES=30
DATABASE_CONNECT_RETRY_DELAY_SECONDS=2
SEED_DATABASE=true
DEFAULT_ADMIN_PASSWORD=password123
PASSWORD_HASH_ITERATIONS=210000
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@turcomp.local
SMTP_USE_TLS=true
RESET_TOKEN_EXPIRE_MINUTES=30
